# =========================================================
# AGV SERVER ENVIRONMENT TEMPLATE
# Copy this file to .env and replace placeholder values.
# DO NOT put real keys in this .env.example file.
# =========================================================


# ---------------------------------------------------------
# SERVER 8790 — LiveKit Token Server
# ---------------------------------------------------------
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
LIVEKIT_TOKEN_PORT=8790


# ---------------------------------------------------------
# Supabase / Database
# ---------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here


# ---------------------------------------------------------
# SERVER 8793 — Stripe Billing Server
# ---------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key_here
STRIPE_SECRET_KEY=sk_live_or_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

STRIPE_CREATOR_PRICE_ID=price_creator_plan_here
STRIPE_MINISTRY_PRICE_ID=price_ministry_plan_here
STRIPE_CONVENTION_PRICE_ID=price_convention_plan_here
STRIPE_INTERNAL_TEST_PRICE_ID=price_internal_test_plan_here

AGV_APP_BASE_URL=http://127.0.0.1:5175
AGV_SUBSCRIPTION_API_BASE=http://127.0.0.1:8792


# ---------------------------------------------------------
# SERVER 8792 — Subscription Server
# ---------------------------------------------------------
SUBSCRIPTION_PORT=8792


# ---------------------------------------------------------
# SERVER 8787 — Main AGV Server
# ---------------------------------------------------------
PORT=8787
NODE_ENV=development